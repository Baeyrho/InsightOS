# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/insightos"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="insightos"

# Authentication (Auth.js)
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# AI (DeepSeek)
DEEPSEEK_API_KEY="sk-xxxx"

# Payments (Flutterwave)
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-xxxx"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-xxxx"
FLUTTERWAVE_WEBHOOK_SECRET_HASH="your-secret-hash"
FLUTTERWAVE_BASE_URL="https://api.flutterwave.com/v3"
FLUTTERWAVE_PRO_PLAN_ID="xxxx"
FLUTTERWAVE_TEAM_PLAN_ID="xxxx"

# Cache / Rate limit (Upstash Redis)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Storage (UploadThing)
UPLOADTHING_SECRET="sk_live_xxxx"
UPLOADTHING_APP_ID="xxxx"

# Logging
LOG_LEVEL="info"
NODE_ENV="development"

# Email (Nodemailer - SMTP)
# Example: Gmail App Password
#   SMTP_HOST="smtp.gmail.com"
#   SMTP_PORT="587"
#   SMTP_USER="your@gmail.com"
#   SMTP_PASS="your-16-char-app-password"
# Leave empty to log emails to the console (no actual send).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@insightos.app"

# App URL (used in email links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
